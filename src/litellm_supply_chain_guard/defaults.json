    "requirements-dev.txt",
    "constraints.txt",
    "pyproject.toml",
    "Pipfile",
    "poetry.lock",
    "setup.py",
    "setup.cfg",
    "environment.yml",
    "environment.yaml"
  ],
  "venv_dir_names": [".venv", "venv", "env"]
}
