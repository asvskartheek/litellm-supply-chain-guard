{
  "package_name": "litellm",
  "compromised_versions": ["1.82.7", "1.82.8"],
  "ioc_files": ["litellm_init.pth"],
  "persistence_paths": [
    "~/.config/sysmon/sysmon.py",
    "~/.config/systemd/user/sysmon.service"
